{
  "$schema": "https://unpkg.com/wrangler@latest/config-schema.json",
  "name": "favicon-checker",
  "main": ".output/server/index.mjs",
  "assets": {
    "directory": ".output/public"
  },
  "compatibility_date": "2026-03-11",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "observability": {
    "enabled": true
  },
  "routes": [
    {
      "pattern": "favicon-checker.nard.uk",
      "custom_domain": true
    }
  ],
  "triggers": {
    "crons": [
      "23 * * * *"
    ]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "favicon-checker-db",
      "database_id": "6c3b0fe5-e079-480b-8b24-54e1357136a7"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "d057d2df16af49d3977809e46f8e5294",
      "preview_id": "052af52a52ee4e3e87a4ba99b50e43de"
    }
  ]
}
